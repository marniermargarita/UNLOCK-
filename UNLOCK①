<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UNLOCK - Answer</title>
  <style>
    body {
      margin: 0;
      padding: 24px;
      font-family: serif;
      background: #e8dcc8;
      color: #2b2118;
      text-align: center;
    }

    .card {
      max-width: 420px;
      margin: 40px auto;
      padding: 28px;
      background: #f4ead8;
      border: 1px solid #7a6248;
      box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }

    h1 {
      letter-spacing: 4px;
    }

    input {
      width: 80%;
      padding: 12px;
      font-size: 18px;
      text-align: center;
      border: 1px solid #7a6248;
      background: #fffaf0;
    }

    button {
      margin-top: 16px;
      padding: 12px 28px;
      font-size: 16px;
      background: #2b2118;
      color: white;
      border: none;
      cursor: pointer;
    }

    #message {
      margin-top: 20px;
      min-height: 24px;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>UNLOCK</h1>
    <p>導かれた答えを入力してください。</p>

    <input id="answer" type="text" placeholder="ANSWER">
    <br>
    <button onclick="checkAnswer()">解錠する</button>

    <p id="message"></p>
  </div>

  <script>
    function normalize(text) {
      return text
        .trim()
        .toLowerCase()
        .replace(/\s+/g, "");
    }

    function checkAnswer() {
      const input = normalize(document.getElementById("answer").value);
      const correct = "memory"; // ここを正解に変える

      if (input === correct) {
        window.location.href = "success.html";
      } else {
        document.getElementById("message").textContent =
          "鍵はまだ開かないようだ。";
      }
    }
  </script>
</body>
</html>
